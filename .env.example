# Umami Analytics — 隐私友好分析
# 无 cookie，GDPR 合规，不收集个人数据
#
# 接入步骤:
# 1. 在 https://cloud.umami.is 注册免费账号（100K events/月，3 个网站）
# 2. 添加网站，获取 Website ID（Settings → Websites → 你的网站 → Tracking code）
# 3. 将 Website ID 填入下方
# 4. 如使用自部署 Umami 实例，修改 VITE_UMAMI_SCRIPT_URL
#
# 留空则不加载分析脚本（本地开发建议留空）

VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
